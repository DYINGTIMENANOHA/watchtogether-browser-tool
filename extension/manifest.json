{
  "manifest_version": 3,
  "name": "WatchTogether",
  "version": "1.1.0",
  "description": "Sync YouTube and Bilibili playback with friends",
  "permissions": ["storage", "tabs", "alarms", "idle"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.bilibili.com/*",
    "https://search.bilibili.com/*",
    "https://streamforsoul.com/*",
    "https://*.streamforsoul.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "minimum_chrome_version": "103",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "options_page": "settings/settings.html",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["i18n/strings.js", "content/adapters/youtube.js", "content/content.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bilibili.com/*", "https://search.bilibili.com/*"],
      "js": ["i18n/strings.js", "content/adapters/bilibili.js", "content/content.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "watchtogether@streamforsoul.com",
      "strict_min_version": "109.0"
    }
  }
}
